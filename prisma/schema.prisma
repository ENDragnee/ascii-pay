generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  password String
  agencyId String?
  agency   Agency? @relation(fields: [agencyId], references: [id])

  roleUsers RoleUser[]
  sessions  Session[]
  logs      Log[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("users")
}

model Role {
  id              String           @id @default(cuid())
  guardName       String           @unique
  roleUsers       RoleUser[]
  permissionRoles PermissionRole[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("roles")
}

model Permission {
  id              String           @id @default(cuid())
  guardName       String           @unique
  permissionRoles PermissionRole[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("permissions")
}

model RoleUser {
  id     String @id @default(cuid())
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  roles  Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([userId, roleId])
  @@map("role_users")
}

model PermissionRole {
  id           String     @id @default(cuid())
  permissionId String
  roleId       String
  permissions  Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  roles        Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([permissionId, roleId])
  @@map("permission_roles")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("sessions")
}

model Log {
  id       String  @id @default(cuid())
  type     String
  severity String
  message  String
  userId   String?
  user     User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("logs")
}

model Agency {
  id           String        @id @default(cuid())
  name         String
  phone        String
  balance      Float         @default(0.0)
  users        User[]
  products     Product[]
  customers    Customer[]
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("agencies")
}

model Product {
  id           String        @id @default(cuid())
  name         String
  price        Float
  agencyId     String
  agency       Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("products")
}

model Customer {
  id            String        @id @default(cuid())
  name          String
  phone         String
  defaultAmount Float?
  agencyId      String
  agency        Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  transactions  Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("customers")
}

enum TransactionStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

model Transaction {
  id     String            @id @default(cuid())
  amount Float
  status TransactionStatus @default(PENDING)
  type   String            @default("USSD_PUSH")

  agencyId   String
  customerId String
  productId  String?

  agency   Agency   @relation(fields: [agencyId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  product  Product? @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("transactions")
}
